{
    "extends": "@vue/tsconfig/tsconfig.dom.json",
    "include": ["src/**/*", "src/**/*.vue", "env.d.ts"],
    "exclude": ["./src/**/*.spec.ts", "./src/**/*.spec.js", "./src/**/*.stories.ts", "./src/**/*.stories.js"],
    "compilerOptions": {
        "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
        "allowJs": true,
        "declaration": true,
        "declarationMap": true,
        "emitDeclarationOnly": false,
        "outDir": "./dist",
        // "sourceMap": true,
        // "watch": true
        "paths": {
            "@/*": ["./src/*"],
        }
    }
}
