<!DOCTYPE html>
<html lang="ru">
<head>
    @* Инициализация dataLayer *@
    <script>
    window.dataLayer = window.dataLayer || [];
    </script>
    
    <!-- Google Tag Manager -->
    <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer','GTM-P7DMFQ2');</script>
    <!-- End Google Tag Manager -->
    
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    
    @* Стили из dist *@
    <script type="module" crossorigin src="~/dist/assets/index-BVxHbGax.js" asp-append-version="true"></script>
    <link rel="stylesheet" crossorigin href="~/dist/assets/index-7m7CaXNW.css" asp-append-version="true" />
    
    <style>
        body {
            margin: 0;
        }
    </style>
    
    @* Универсальная валидация форм *@
    <script src="~/form-validator.js"></script>
    
    @* Обработчик кнопки "Назад" с backUrl и OIDC (только для Login) *@
    <script src="~/back-button-handler-oidc.js"></script>
</head>
<body>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-P7DMFQ2" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    
    <header id="header"></header>

    @* Кнопка "Назад" *@
    <div class="back-button-container">
        <button class="back-button" onclick="window.history.back()">
            <img
                src="~/dist/icons/arrow-back-circle.svg"
                alt="Назад"
                width="40"
                height="40"
                class="back-button__icon-desktop"
            />
            
            <span class="back-button__mobile">
                <img
                    src="~/dist/icons/arrow-back.svg"
                    alt="←"
                    width="6"
                    height="10"
                />
                <span class="footnote_M c-cornflower">Назад</span>
            </span>
        </button>
    </div>

    <main class="main-content flex flex-d-c jc-center ai-c px-20 py-40 bg-gray-5 md3-p-16" style="min-height: 60vh;">
        @RenderBody()
    </main>

    <footer id="footer"></footer>
    
    @* Props для компонентов (читаются из скомпилированного кода) *@
    <script>
        // Глобальные props для Header/Footer
        window.__HEADER_PROPS__ = {
            locale: 'ru',
            baseUrl: 'https://fstravel.com',
            authType: 'oidc',
            oidcAuthorityUrl: 'https://auth2.fstravel.com',
            blockedAuth: true
        };
        
        window.__FOOTER_PROPS__ = {
            baseUrl: 'https://fstravel.com'
        };
    </script>
</body>
</html>
