@page
@using FunSun.Auth.Pages.ForgotPassword
@inject IHtmlLocalizer<IndexModel> Localizer
@model IndexModel
@{
    ViewData["Title"] = Localizer["Title"];
}
<div>
    <h1>@Localizer["Title"]</h1>
    <h2>@Localizer["Description"]</h2>
    <hr />
    @if (Model.Errors.Any())
    {
        <div class="row">
            <div class="col-md-4">
                @foreach (var error in Model.Errors)
                {
                    <p class="text-danger">@error</p>
                }
            </div>
        </div>
    }
    <div class="row">
        <div class="col-md-4">
            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                <div class="form-floating mb-3">
                    <input asp-for="ChangePasswordInput.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                    <label asp-for="ChangePasswordInput.Email" class="form-label"></label>
                </div>
                <button type="submit" class="w-100 btn btn-lg btn-primary">@Localizer["ResetPasswordButton"]</button>
            </form>
        </div>
    </div>
</div>
