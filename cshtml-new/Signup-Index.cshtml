@page
@using FunSun.Auth.Pages.Signup
@inject IHtmlLocalizer<IndexModel> Localizer
@model IndexModel
@{
    ViewData["Title"] = Localizer["Title"];
}

<h2 class="Heading_1 m-0 mb-32">Регистрация</h2>

<div class="auth-card bg-white radius-16 shadow-5dp py-32 px-24 w-100p md3-py-24 md3-px-16">
    <form id="registerForm" method="post">

        <web-input-phone
            class="mb-20 md3-mb-16"
            name="SignUpInput.Phone"
            label="Телефон"
            include-codes='["RU"]'
            placeholder="(960) 123-12-12"
        ></web-input-phone>

        <web-input
            class="mb-8 md3-mb-16"
            name="SignUpInput.Email"
            type="email"
            placeholder="name@example.com"
            label="Email"
            autocomplete="username"
        ></web-input>

        <div class="mb-20 md3-mb-16 footnote_M c-gray signup-hint-text">
            Разрешены российские домены @@yandex.ru, @@vk.com, @@mail.ru и другие
        </div>

        <web-input-password
            class="mb-20 md3-mb-16"
            name="SignUpInput.Password"
            placeholder="password"
            label="Пароль"
            autocomplete="new-password"
        ></web-input-password>

        <web-input-password
            class="mb-20 md3-mb-16"
            name="SignUpInput.ConfirmPassword"
            placeholder="password"
            label="Подтвердить пароль"
            autocomplete="new-password"
        ></web-input-password>

        <div class="signup-buttons flex ai-c mb-16" style="gap: 16px;">
            <web-button
                id="registerSubmit"
                type="submit"
                class="button_yellow radius-8 w-100p"
            >
                Зарегистрироваться
            </web-button>

            <web-button class="button_alternate button_no-border radius-8 w-100p">
                Войти
            </web-button>
        </div>

        <div class="signup-agreement footnote_L c-gray">
            Нажимая на кнопку, я даю
            <a href="/privacy" class="c-cornflower">«Согласие на обработку персональных данных»</a>,
            ознакомлен и принимаю условия
            <a href="/terms" class="c-cornflower">Пользовательского соглашения</a>
        </div>
    </form>
</div>
