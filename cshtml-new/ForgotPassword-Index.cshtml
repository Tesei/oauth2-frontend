@page
@using FunSun.Auth.Pages.ForgotPassword
@inject IHtmlLocalizer<IndexModel> Localizer
@model IndexModel
@{
    ViewData["Title"] = Localizer["Title"];
}

<script>

// Событие: ошибка при восстановлении
function sendErrorRestorePassword(errorText) {
    dataLayer.push({
        event: "error_restore_password",
        event_action: errorText
    });
}

// Автоматический tracking ошибок
document.addEventListener('DOMContentLoaded', () => {
    const form = document.querySelector('#forgot-password-form');
    if (!form) return;
    
    const emailInput = form.querySelector('[name="Email"]');
    
    // Server-side ошибка (при загрузке)
    // Способ 1: Через атрибут (быстро)
    let error = emailInput?.getAttribute('error-text');
    
    // Способ 2: Через DOM (fallback)
    if (!error) {
        error = form.querySelector('.input__error-text')?.textContent.trim();
    }
    
    if (error) {
        sendErrorRestorePassword(error);
    }
    
    // Client-side ошибка (при submit)
    form.addEventListener('submit', () => {
        setTimeout(() => {
            const errorAfterSubmit = form.querySelector('.input__error-text')?.textContent.trim();
            if (errorAfterSubmit) {
                sendErrorRestorePassword(errorAfterSubmit);
            }
        }, 100);
    });
});
</script>

<h2 class="Heading_1 m-0 mb-32">Восстановление пароля</h2>

<div class="auth-card bg-white radius-16 shadow-5dp py-32 px-24 w-100p md3-py-24 md3-px-16">
    <form id="forgot-password-form" method="post">

        <p class="forgot-password__text c-black mb-24">
            Пожалуйста, укажите вашу почту, мы отправим электронное письмо для восстановления пароля. Если оно не придет, обязательно проверьте папку со спамом
        </p>

        <web-input
            class="mb-24"
            name="Email"
            type="email"
            placeholder="Введите email для восстановления*"
            label="Email"
            autocomplete="email"
            validate-on-blur
        ></web-input>

        <web-button id="submit-reset" type="submit" class="button_yellow w-100p">
            Отправить
        </web-button>
    </form>
</div>
