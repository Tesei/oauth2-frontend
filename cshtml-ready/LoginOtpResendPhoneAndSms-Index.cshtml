@page
@using FunSun.Auth.Pages.LoginOtpResendPhoneAndSms
@inject IHtmlLocalizer<IndexModel> Localizer
@model IndexModel
@{
    ViewData["Title"] = Localizer["Title"];
}

<div class="auth-card auth-card--otp">
    <div class="p-12 md3-p-8">
        <web-button-control
            onclick="window.history.back()"
            class="js-back-button"
        >
            <svg class="icon" width="24" height="24" aria-hidden="true">
                <use href="/sprite.svg#arrow--arrow-left-2"></use>
            </svg>
        </web-button-control>
    </div>
    

    <div class="mx-32 md3-mx-16 mb-48">
        <div class="heading_3 mb-12 text-center">Введите последние 4 цифры<p>входящего номера</p></div>
        <div class="body_S c-text-secondary mb-8 text-center">
            Мы позвоним на <span class="c-text-primary">+7 999 000 00 00</span>
            <br>Отвечать на звонок не нужно            
        </div>
        <a href="/" class="block brand-link-button_S text-center">Изменить номер</a>
    </div>
    <div class="mb-48 text-center">
        <form
            id="otp-code"
            class="flex gap-12 ai-c jc-c"
        >
            <web-input-otp-cell
                has-error
                value="1"
            ></web-input-otp-cell>
            <web-input-otp-cell
                has-error
                value="2"
            ></web-input-otp-cell>
            <web-input-otp-cell has-error
            ></web-input-otp-cell>
            <web-input-otp-cell has-error
            ></web-input-otp-cell>            
        </form>
        <span class="c-text-error caption_M mt-8 block">Неверный код. Повторите попытку</span>
    </div>


    <div class="text-center mb-64">
        <a href="/login-otp-phone" class="block brand-link-button_S text-center">Получить новый код</a>
        <br>
        <a href="/login-otp-sms" class="block brand-link-button_S text-center">Получить код через SMS</a>
    </div>
</div>
